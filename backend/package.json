{
  "name": "context-os-backend",
  "version": "0.1.0",
  "description": "Context OS Backend - P0 Implementation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:up": "node-pg-migrate --config-file .migrate.json up",
    "migrate:down": "node-pg-migrate --config-file .migrate.json down",
    "migrate:create": "node-pg-migrate --config-file .migrate.json create",
    "db:up": "docker compose -f ../docker-compose.yml up -d",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:setup": "npm run db:up && npm run migrate:up",
    "db:reset": "docker compose -f ../docker-compose.yml down -v && npm run db:setup",
    "scheduler": "tsx src/scheduler.ts",
    "server": "tsx src/server.ts",
    "server:watch": "tsx watch src/server.ts",
    "test:crud": "DATABASE_URL=postgresql://context_os:context_os_dev@localhost:5432/context_os_dev tsx src/test-crud.ts",
    "test:dream": "DREAM_TEST_USE_MOCK=1 tsx src/test-dream.ts",
    "test:dream:live": "tsx src/test-dream.ts",
    "test:extraction": "tsx src/test-extraction.ts",
    "test:briefing": "BRIEFING_TEST_USE_MOCK=1 tsx src/test-briefing.ts",
    "test:briefing:live": "tsx src/test-briefing.ts",
    "test:handoff": "tsx src/test-handoff.ts",
    "test:chat": "DATABASE_URL=postgresql://context_os:context_os_dev@localhost:5432/context_os_dev tsx src/test-chat.ts",
    "test:artifact": "DATABASE_URL=postgresql://context_os:context_os_dev@localhost:5432/context_os_dev ARTIFACT_TEST_USE_MOCK=1 tsx src/test-artifact.ts",
    "test:artifact:live": "DATABASE_URL=postgresql://context_os:context_os_dev@localhost:5432/context_os_dev tsx src/test-artifact.ts",
    "test:archive": "DATABASE_URL=postgresql://context_os:context_os_dev@localhost:5432/context_os_dev ARCHIVE_TEST_USE_MOCK=1 tsx src/test-archive.ts",
    "test:archive:live": "DATABASE_URL=postgresql://context_os:context_os_dev@localhost:5432/context_os_dev tsx src/test-archive.ts",
    "test:scheduler": "DREAM_TEST_USE_MOCK=1 tsx src/test-scheduler.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "pg": "^8.11.3",
    "yaml": "^2.8.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.0.2",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
